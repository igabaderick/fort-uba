# Copy this to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/fortuba

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# OTP (set to true to use real SMS — requires Africa's Talking or similar)
USE_REAL_SMS=false
SMS_API_KEY=
SMS_SENDER_ID=FORTUBA

# MTN Mobile Money (requires registered business account)
MTN_MOMO_ENABLED=false
MTN_MOMO_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_PRIMARY_KEY=
MTN_MOMO_SECONDARY_KEY=

# Frontend URLs (for CORS)
RIDER_APP_URL=http://localhost:5173
DRIVER_APP_URL=http://localhost:5174
ADMIN_APP_URL=http://localhost:5175
